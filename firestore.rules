rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - displayName: string (optional) - User's public name
    //   - username: string (optional) - Unique handle
    //   - email: string (optional) - User's email
    //   - photoURL: string (optional) - User's photo URL
    //   - coverURL: string (optional) - User's cover photo URL
    //   - isVerified: boolean (optional) - Verification status
    //   - neuroType: string (required) - Neurodivergent profile ID
    //   - customTheme: map (optional) - primaryColor, secondaryColor, fontSize, highContrast
    //   - bio: string (optional) - User's bio
    //   - linkInBio: string (optional) - External link
    //   - contactInfo: map (optional) - email, twitter, discord
    //   - metrics: map (optional) - followers, following, mutuals
    //   - intro: map (optional) - bio, location, company
    //   - createdAt: timestamp (optional) - Creation date
    //   - updatedAt: timestamp (optional) - Last update date
    //
    // Collection: posts
    // Document ID: {postId}
    // Fields:
    //   - uid: string (required) - Author UID
    //   - authorName: string (optional) - Author's name
    //   - authorPhoto: string (optional) - Author's photo
    //   - content: string (required) - Post content
    //   - mediaUrl: string (optional) - Media URL
    //   - mediaType: string (optional) - image, video, none
    //   - chartMarkup: string (optional) - JSON string of chart annotations
    //   - likesCount: int (optional) - Number of likes
    //   - createdAt: timestamp (required) - Creation date
    //
    // Collection: about
    // Document ID: main
    // Fields:
    //   - title: string (optional) - Section title
    //   - body: string (optional) - Section body
    //   - lastUpdated: timestamp (optional) - Last update date
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "forexanarchy@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUserCreate(data) {
      let allowedFields = [
        'uid', 'displayName', 'username', 'email', 'photoURL', 'coverURL', 
        'isVerified', 'neuroType', 'customTheme', 'bio', 'keywords', 
        'linkInBio', 'contactInfo', 'metrics', 'intro', 'createdAt', 'updatedAt',
        'role', 'pinnedPostId'
      ];
      let neuroTypes = [
        'calm_focus', 'low_stim_emergency', 'dyslexia_readable', 'dyscalculia_numeric_relief',
        'visual_processing_safe', 'apd_assist', 'executive_function_support', 'motor_friendly',
        'adhd_dopamine_balanced', 'adhd_hyperfocus', 'autism_predictable', 'tourette_tic_friendly',
        'plain_language', 'high_contrast', 'custom_neuro_mix', 'corporate_open', 'retail_chaos',
        'retail_modular', 'vr_assistive', 'standard_trader',
        'ADHD', 'AUTISM', 'PTSD', 'TBI', 'DOWNS', 'VETERAN', 'STANDARD', 'adhd', 'asd', 'dyslexia', 'dyscalculia', 'dyspraxia-dcd', 'tourette-tics', 'ocd', 'ptsd', 'anxiety', 'bipolar', 'sensory-processing', 'tbi', 'apd-capd', 'visual-processing', 'executive-function', 'schizophrenia', 'depression', 'fetal-alcohol', 'intellectual-disability', 'misophonia', 'standard', 'downs', 'military'
      ];
      
      return data.keys().hasAll(['uid', 'neuroType']) &&
             data.keys().hasOnly(allowedFields) &&
             data.uid is string &&
             data.neuroType in neuroTypes &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('username' in data) || (data.username is string && data.username.size() < 50)) &&
             (!('email' in data) || (data.email is string && data.email.size() < 200)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 10000000)) &&
             (!('coverURL' in data) || (data.coverURL is string && data.coverURL.size() < 10000000)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 5000)) &&
             (!('linkInBio' in data) || (data.linkInBio is string && data.linkInBio.size() < 200)) &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('customTheme' in data) || data.customTheme is map) &&
             (!('contactInfo' in data) || data.contactInfo is map) &&
             (!('metrics' in data) || data.metrics is map) &&
             (!('intro' in data) || data.intro is map) &&
             (!('keywords' in data) || data.keywords is list) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidUserUpdate(data) {
      let allowedFields = [
        'uid', 'displayName', 'username', 'email', 'photoURL', 'coverURL', 
        'isVerified', 'neuroType', 'customTheme', 'bio', 'keywords', 
        'linkInBio', 'contactInfo', 'metrics', 'intro', 'createdAt', 'updatedAt',
        'role', 'pinnedPostId'
      ];
      let neuroTypes = [
        'calm_focus', 'low_stim_emergency', 'dyslexia_readable', 'dyscalculia_numeric_relief',
        'visual_processing_safe', 'apd_assist', 'executive_function_support', 'motor_friendly',
        'adhd_dopamine_balanced', 'adhd_hyperfocus', 'autism_predictable', 'tourette_tic_friendly',
        'plain_language', 'high_contrast', 'custom_neuro_mix', 'corporate_open', 'retail_chaos',
        'retail_modular', 'vr_assistive', 'standard_trader',
        'ADHD', 'AUTISM', 'PTSD', 'TBI', 'DOWNS', 'VETERAN', 'STANDARD', 'adhd', 'asd', 'dyslexia', 'dyscalculia', 'dyspraxia-dcd', 'tourette-tics', 'ocd', 'ptsd', 'anxiety', 'bipolar', 'sensory-processing', 'tbi', 'apd-capd', 'visual-processing', 'executive-function', 'schizophrenia', 'depression', 'fetal-alcohol', 'intellectual-disability', 'misophonia', 'standard', 'downs', 'military'
      ];
      
      return data.keys().hasOnly(allowedFields) &&
             (!('uid' in data) || data.uid is string) &&
             (!('neuroType' in data) || data.neuroType in neuroTypes) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('username' in data) || (data.username is string && data.username.size() < 50)) &&
             (!('email' in data) || (data.email is string && data.email.size() < 200)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 10000000)) &&
             (!('coverURL' in data) || (data.coverURL is string && data.coverURL.size() < 10000000)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 5000)) &&
             (!('linkInBio' in data) || (data.linkInBio is string && data.linkInBio.size() < 200)) &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('customTheme' in data) || data.customTheme is map) &&
             (!('contactInfo' in data) || data.contactInfo is map) &&
             (!('metrics' in data) || data.metrics is map) &&
             (!('intro' in data) || data.intro is map) &&
             (!('keywords' in data) || data.keywords is list) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidPost(data) {
      let allowedFields = [
        'uid', 'authorName', 'authorPhoto', 'content', 'mediaUrl', 
        'mediaType', 'likesCount', 'createdAt', 'chartMarkup', 'market_layer'
      ];
      
      return data.keys().hasAll(['uid', 'content', 'createdAt']) &&
             data.keys().hasOnly(allowedFields) &&
             data.uid is string &&
             data.content is string && data.content.size() < 10000 &&
             data.createdAt is timestamp &&
             (!('authorName' in data) || (data.authorName is string && data.authorName.size() < 100)) &&
             (!('authorPhoto' in data) || (data.authorPhoto is string && data.authorPhoto.size() < 2000)) &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() < 1000000)) &&
             (!('mediaType' in data) || data.mediaType in ['image', 'video', 'none']) &&
             (!('likesCount' in data) || data.likesCount is int) &&
             (!('market_layer' in data) || (data.market_layer is string && data.market_layer.size() < 20)) &&
             (!('chartMarkup' in data) || (data.chartMarkup is string && data.chartMarkup.size() < 1000000));
    }

    function isValidRoom(data) {
      let allowedFields = ['sheep_count', 'pulse_state'];
      return data.keys().hasOnly(allowedFields) &&
             (!('sheep_count' in data) || data.sheep_count is int) &&
             (!('pulse_state' in data) || (data.pulse_state is string && data.pulse_state.size() < 50));
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['uid', 'role', 'text', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.role in ['user', 'model'] &&
             data.text is string && data.text.size() < 100000 &&
             data.timestamp is timestamp;
    }

    function isValidAIAsset(data) {
      return data.keys().hasAll(['uid', 'type', 'url', 'prompt', 'model', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.type in ['image', 'video'] &&
             data.url is string && data.url.size() < 1000000 &&
             data.prompt is string && data.prompt.size() < 5000 &&
             data.model is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.uid == request.auth.uid;
        allow create: if isAuthenticated() && isValidChatMessage(request.resource.data);
      }
    }

    match /ai_assets/{assetId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAIAsset(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUserCreate(request.resource.data);
      allow update: if isOwner(uid) && isValidUserUpdate(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid &&
                      (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt);
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid && 
                      isValidPost(request.resource.data) &&
                      request.resource.data.likesCount == 0 &&
                      request.resource.data.createdAt == request.time;
      allow update: if isAuthenticated() && 
                      (resource.data.uid == request.auth.uid || isAdmin()) && 
                      isValidPost(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /about/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system/intelligence_status {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
                      (!('lastRun' in request.resource.data) || request.resource.data.lastRun is timestamp) &&
                      (!('itemCount' in request.resource.data) || request.resource.data.itemCount is int);
    }
  }
}
