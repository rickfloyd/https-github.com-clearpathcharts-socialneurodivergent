rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // DEFAULT DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // HELPER FUNCTIONS
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == "forexanarchy@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // VALIDATION BLUEPRINTS
    // ===============================================================

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.uid is string &&
             data.interfaceType is string &&
             (!('email' in data) || (data.email is string && data.email.size() < 200)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 200));
    }

    function isValidPost(data) {
      let allowedFields = [
        'uid', 'authorName', 'authorPhoto', 'content', 'mediaUrl', 
        'mediaType', 'likesCount', 'createdAt', 'chartMarkup', 'market_layer'
      ];
      return data.keys().hasAll(['uid', 'content', 'createdAt']) &&
             data.keys().hasOnly(allowedFields) &&
             data.uid == request.auth.uid &&
             data.content is string && data.content.size() < 10000 &&
             data.createdAt == request.time;
    }

    function isValidTrade(data) {
      return data.uid == request.auth.uid &&
             data.pair is string && data.pair.size() < 20 &&
             data.direction in ['long', 'short'] &&
             data.timeframe is string &&
             data.entry is number &&
             data.sl is number &&
             data.tp is number &&
             data.outcome in ['good', 'bad'] &&
             data.createdAt == request.time;
    }

    function isValidChat(data) {
      return data.uid == request.auth.uid &&
             data.role in ['user', 'model'] &&
             data.text is string && data.text.size() < 100000 &&
             data.timestamp == request.time;
    }

    function isValidAIAsset(data) {
      return data.uid == request.auth.uid &&
             data.type in ['image', 'video'] &&
             data.url is string && data.url.size() < 1000000 &&
             data.createdAt == request.time;
    }

    function isValidTask(data) {
      return data.uid == request.auth.uid &&
             data.title is string && data.title.size() < 1000 &&
             data.completed is bool &&
             (!('dueDate' in data) || data.dueDate == null || data.dueDate is timestamp) &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // ACCESS RULES
    // ===============================================================

    // Users & Profiles
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if (isOwner(uid) || isAdmin()) && (
        isAdmin() || (
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'displayName', 'username', 'email', 'photoURL', 'coverURL', 'photoUrl', 'coverUrl',
            'interfaceType', 'neuroType', 'customTheme', 'bio', 'keywords', 
            'linkInBio', 'contactInfo', 'metrics', 'intro', 'updatedAt',
            'pinnedPostId', 'instagram', 'website', 'lastLegalAck', 'lastLogin', 'lastActive', 'status'
          ])
        )
      );

      // Journal Trades
      match /trades/{tradeId} {
        allow read, write: if isOwner(uid);
      }

      // Journal Settings
      match /settings/journal {
        allow read, write: if isOwner(uid);
      }

      // Tactical Tasks
      match /tasks/{taskId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidTask(request.resource.data);
        allow update: if isOwner(uid) && (
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'completed', 'dueDate', 'updatedAt'])
        );
        allow delete: if isOwner(uid);
      }
    }

    // Global Timeline Posts
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPost(request.resource.data);
      allow update: if (isOwner(resource.data.uid) || isAdmin()) && 
                      isValidPost(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    // AI Lab Chats
    match /chats/{chatId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && isValidChat(request.resource.data);
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // AI Lab Assets
    match /ai_assets/{assetId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidAIAsset(request.resource.data);
      allow delete: if (isSignedIn() && resource.data.uid == request.auth.uid) || isAdmin();
    }

    // Static Content
    match /about/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // System Intelligence
    match /system/intelligence_status {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Legacy support (optional, clean up if POSITIVELY unused)
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
